<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NeoDPI" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neo_accent</item>
        <item name="colorOnPrimary">@color/neo_text_primary</item>
        <item name="android:windowBackground">@color/neo_bg</item>
        <item name="android:statusBarColor">@color/neo_bg</item>
        <item name="android:navigationBarColor">@color/neo_bg</item>
        <item name="colorSurface">@color/neo_surface</item>
        <item name="colorOnSurface">@color/neo_text_primary</item>
        <item name="colorControlActivated">@color/neo_accent</item>
        <item name="materialCardViewStyle">@style/SmallShadowCard</item>
        <item name="switchPreferenceStyle">@style/App.Preference.SwitchPreference</item>
    </style>

    <style name="CircleButton" parent="Widget.Material3.Button.Icon">
        <item name="cornerRadius">60dp</item>
        <item name="android:textSize">0sp</item>
    </style>

    <style name="App.Preference.SwitchPreference" parent="Preference.SwitchPreference.Material">
        <item name="android:widgetLayout">@layout/material_switch</item>
    </style>

    <style name="ActionBarTheme" parent="Widget.AppCompat.ActionBar.Solid">
        <item name="background">@color/neo_surface</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="ActionBarTextTheme" parent="ThemeOverlay.Material3.ActionBar">
        <item name="android:textColorPrimary">@color/neo_text_primary</item>
        <item name="android:textColorSecondary">@color/neo_text_secondary</item>
    </style>

    <style name="CustomAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:windowBackground">@drawable/material_alert</item>
        <item name="android:textColorPrimary">@color/neo_text_primary</item>
        <item name="android:textColorSecondary">@color/neo_text_secondary</item>
    </style>

    <style name="SmallShadowCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/neo_card</item>
        <item name="cardCornerRadius">16dp</item>
    </style>

    <style name="TextPrimary" parent="TextAppearance.AppCompat.Title">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextSummary" parent="TextAppearance.AppCompat.Subhead">
        <item name="android:textSize">14sp</item>
    </style>
</resources>
